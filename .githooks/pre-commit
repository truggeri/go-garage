#!/bin/sh
# Pre-commit hook for Go-Garage project
# Runs formatting and basic checks before allowing commit

echo "Running pre-commit checks..."

# Format all staged Go files
echo "Formatting Go files..."
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$')

if [ -n "$STAGED_GO_FILES" ]; then
    for file in $STAGED_GO_FILES; do
        gofmt -s -w "$file"
        git add "$file"
    done
fi

# Run go vet on staged files
echo "Running go vet..."
if ! go vet ./...; then
    echo "go vet failed. Please fix the issues before committing."
    exit 1
fi

# Check for common issues
echo "Checking for common issues..."
if ! go fmt ./...; then
    echo "go fmt found formatting issues. Files have been formatted."
    exit 1
fi

echo "Pre-commit checks passed!"
exit 0
